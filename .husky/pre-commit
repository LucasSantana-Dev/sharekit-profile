#!/usr/bin/env bash
# Pre-commit hook — runs quality gates before each commit

set -e

echo "Running pre-commit checks..."

# Check for bot Co-authored-by trailers
python3 scripts/check-coauthor-trailers.py

# Check harness/app boundary
bash scripts/check-harness-boundary.sh

# Check harness manifest fingerprints
bash scripts/check-harness-manifest.sh

# Schema + security validation for skills in this catalog
bash hooks/skill-validate.sh --dir claude/skills

# Stale-showcase check (local only; skips gracefully in CI where canonical is
# absent). HARD-FAIL since 2026-07-01: page↔canonical reached fully-clean state
# after the canonical prune was mirrored (PR #29), fulfilling the ADR-0001
# flip condition. If this blocks a commit, the page lists a skill that no
# longer exists in ~/.claude/skills — fix the page (or the canonical), don't
# re-soften this gate.
bash scripts/check-catalog-canonical.sh

# Shell script linting with shellcheck (graceful degrade if not installed)
if command -v shellcheck >/dev/null 2>&1; then
  shellcheck -S warning hooks/*.sh hooks/shared/*.sh scripts/*.sh
else
  echo "skip: shellcheck not installed (install via: brew install shellcheck)"
fi

echo "Pre-commit checks passed."
