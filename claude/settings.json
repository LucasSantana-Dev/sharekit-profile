{
  "schema": "harness-settings/v1",
  "comment": "Registers the sharekit-profile hook scripts to Claude Code lifecycle events. This file is the missing enforcement layer — without it, the hooks/ scripts are orphan artifacts and 9/15 RULES.md 'Must Always' rules are advisory-only. Exit code 2 is the only blocking code; all other exits are advisory/log-only. Hosts that do not implement a given event ignore its entry.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/session-start-load.sh\"",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "OBSERVE_HOOK_EVENT=SessionStart bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/observe-otel.sh\"",
            "timeout": 2000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/check-dangerous-patterns.sh\"",
            "timeout": 2000
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/check-pr-automation-halt.sh\"",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/check-stuck-loop.sh\"",
            "timeout": 2000
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/check-idempotency.sh\"",
            "timeout": 2000
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/check-idempotency.sh\"",
            "timeout": 2000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/trajectory-log.sh\"",
            "timeout": 2000
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/context-guard.sh\"",
            "timeout": 2000
          },
          {
            "type": "command",
            "command": "OBSERVE_HOOK_EVENT=PostToolUse bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/observe-otel.sh\"",
            "timeout": 2000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/check-read-only-subagent.sh\"",
            "timeout": 2000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/snapshot-compact.sh\"",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/reinject-compact.sh\"",
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/post-incident-adr.sh\"",
            "timeout": 3000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/session-end-flush.sh\"",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "OBSERVE_HOOK_EVENT=SessionEnd bash \"${CLAUDE_PROJECT_DIR:-.}/hooks/observe-otel.sh\"",
            "timeout": 2000
          }
        ]
      }
    ]
  },
  "hook_firing_order_doc": "docs/hook-firing-order.md",
  "runtime_dir": ".harness/runtime",
  "runtime_dir_note": "Append-only trajectory, session records, compaction snapshots, incident stubs, and the distill pending queue. Gitignored — see .gitignore."
}
