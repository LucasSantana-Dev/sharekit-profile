# Wrangler local cache (contains account id)
warp/.wrangler/

# Scratch / example / backup files not part of the profile
src/
index.html.bak-*
.agent-native/

# Harness runtime (hook trajectory logs, session records, compaction snapshots,
# incident stubs, distill pending queue). Append-only, machine-generated.
.harness/runtime/

# Harness forge (distill-staged candidate learnings + assembled proposals).
# Machine-generated runtime fuel; graduated learnings are promoted into
# committed memory/skills via review.sh, so the staging area itself is not tracked.
.harness/forge/

# Harness eval run output (A/B bench results from eval-run.sh).
# Machine-generated test artifacts; the task catalog (eval-tasks.sh) is source
# and stays tracked, only the run output under .harness/eval/<name>/runs.jsonl is runtime.
.harness/eval/
